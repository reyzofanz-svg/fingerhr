generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER AUTH (NextAuth)
// ============================================

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  password         String
  role             UserRole  @default(VIEWER)
  image            String?
  emailVerified    DateTime? @map("email_verified")
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================
// EMPLOYEE (Data Karyawan)
// ============================================

model Employee {
  id         String   @id @default(cuid())
  pin        String   @unique // PIN di mesin absensi
  name       String
  email      String?  @unique
  phone      String?
  department String?
  position   String?
  isActive   Boolean  @default(true) @map("is_active")
  // Telegram (untuk notifikasi absensi) — chatId didapat saat karyawan /start ke bot
  telegramChatId   String? @unique @map("telegram_chat_id")
  telegramUsername String? @map("telegram_username")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  attendanceLogs AttendanceLog[]
  schedules      EmployeeSchedule[]
  permissions    Permission[]

  @@map("employees")
}

// ============================================
// DEVICE (Mesin Absensi)
// ============================================

model Device {
  id        String    @id @default(cuid())
  cloudId   String    @unique @map("cloud_id")
  name      String
  type      String    @default("FINGERPRINT")
  ip        String?
  status    String    @default("OFFLINE")
  timezone  String    @default("Asia/Jakarta")
  lastSync  DateTime? @map("last_sync")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  attendanceLogs AttendanceLog[]

  @@map("devices")
}

// ============================================
// ATTENDANCE LOG (Data Absensi dari Mesin)
// ============================================

model AttendanceLog {
  id           String   @id @default(cuid())
  employeeId   String   @map("employee_id")
  deviceId     String   @map("device_id")
  scanTime     DateTime @map("scan_time")
  verifyMethod String?  @map("verify_method") // 1=Password, 2=Fingerprint, 3=Card
  status       String // "IN" atau "OUT"
  type         String   @default("manual") // "realtime" atau "manual"
  rawPayload   Json?    @map("raw_payload")
  createdAt    DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([deviceId])
  @@index([scanTime])
  @@map("attendance_logs")
}

// ============================================
// SCHEDULE (Jadwal Kerja)
// ============================================

model Schedule {
  id            String   @id @default(cuid())
  name          String // "SM1", "SM2", "Reguler"
  startTime     String   @map("start_time") // "08:30"
  endTime       String   @map("end_time") // "16:30"
  breakStart    String?  @map("break_start") // "12:00"
  breakEnd      String?  @map("break_end") // "13:00"
  overtimeStart String?  @map("overtime_start") // "17:00" - when overtime begins
  overtimeRate  Float    @default(1.5) @map("overtime_rate") // multiplier for OT pay
  graceMinutes  Int      @default(15) @map("grace_minutes") // toleransi terlambat (menit)
  // Batas jendela scan (jam mulai/akhir absensi diterima)
  scanInStart   String?  @map("scan_in_start") // mulai boleh scan masuk, mis "05:00"
  scanInEnd     String?  @map("scan_in_end") // batas akhir scan masuk, mis "11:00"
  scanOutStart  String?  @map("scan_out_start") // mulai boleh scan pulang, mis "14:00"
  scanOutEnd    String?  @map("scan_out_end") // batas akhir scan pulang, mis "23:00"
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workScheduleDays WorkScheduleDay[]

  @@map("schedules")
}

// ============================================
// WORK SCHEDULE (Jadwal Mingguan)
// Pola 7 hari: tiap hari libur atau memakai sebuah Shift
// ============================================

model WorkSchedule {
  id        String   @id @default(cuid())
  name      String // "Jadwal Kantor", "Jadwal Shift Rotasi"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  days      WorkScheduleDay[]
  employees EmployeeSchedule[]

  @@map("work_schedules")
}

model WorkScheduleDay {
  id             String  @id @default(cuid())
  workScheduleId String  @map("work_schedule_id")
  dayOfWeek      Int     @map("day_of_week") // 0=Minggu ... 6=Sabtu
  isDayOff       Boolean @default(false) @map("is_day_off")
  shiftId        String? @map("shift_id") // null jika libur

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  shift        Schedule?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@unique([workScheduleId, dayOfWeek])
  @@index([workScheduleId])
  @@map("work_schedule_days")
}

// ============================================
// EMPLOYEE SCHEDULE (Relasi Karyawan + Jadwal)
// ============================================

model EmployeeSchedule {
  id             String    @id @default(cuid())
  employeeId     String    @map("employee_id")
  workScheduleId String    @map("work_schedule_id")
  effectiveFrom  DateTime  @map("effective_from")
  effectiveTo    DateTime? @map("effective_to")
  createdAt      DateTime  @default(now()) @map("created_at")

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, effectiveFrom])
  @@index([employeeId])
  @@map("employee_schedules")
}

// ============================================
// PERMISSION (Izin: Sakit/CUTI/Izin)
// ============================================

model Permission {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  type       String // "SICK", "CUTI", "IZIN"
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  reason     String?  @db.Text
  notes      String?  @db.Text // admin notes when approving/rejecting
  status     String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  approvedBy String?  @map("approved_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([startDate, endDate])
  @@map("permissions")
}

// ============================================
// API LOG (Riwayat Request API ke Fingerspot)
// ============================================

model ApiLog {
  id              String   @id @default(cuid())
  command         String // "GET_ATTLOG", "SET_USERINFO", "GET_USERINFO", dll
  deviceCloudId   String   @map("device_cloud_id")
  transId         String?  @map("trans_id")
  status          String   @default("PENDING") // "PENDING", "SUCCESS", "FAILED"
  requestPayload  Json?    @map("request_payload")
  responsePayload Json?    @map("response_payload")
  errorMessage    String?  @map("error_message") @db.Text
  duration        Int? // dalam milidetik
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([command])
  @@index([status])
  @@index([createdAt])
  @@map("api_logs")
}

// ============================================
// WEBHOOK LOG (Riwayat Response Webhook)
// ============================================

model WebhookLog {
  id            String   @id @default(cuid())
  type          String // "REALTIME_ATTLOG", "GET_USERINFO", "SET_USERINFO", dll
  deviceCloudId String   @map("device_cloud_id")
  status        String   @default("SUCCESS") // "SUCCESS", "FAILED"
  payload       Json?
  processedAt   DateTime @default(now()) @map("processed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([deviceCloudId])
  @@index([createdAt])
  @@map("webhook_logs")
}

// ============================================
// SYSTEM SETTINGS (Key-Value Store)
// ============================================

model SystemSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
